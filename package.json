{
  "name": "invoicekasi",
  "version": "1.0.0",
  "private": true,
  "workspaces": ["client", "server", "shared"],
  "scripts": {
    "dev": "concurrently --names client,server --prefix-colors cyan,yellow \"npm run dev --prefix client\" \"npm run dev --prefix server\"",
    "build": "npm run build --workspace=shared && npm run build --workspace=client && npm run build --workspace=server",
    "postinstall": "npm run build --workspace=shared",
    "generate-icons": "node scripts/generate-icons.js",
    "start": "NODE_ENV=production node server/dist/index.js",
    "db:push": "npm run db:migrate --prefix server",
    "db:studio": "npm run db:studio --prefix server",
    "check:money": "ts-node --transpile-only --project server/tsconfig.json scripts/check-money.ts"
  },
  "engines": {
    "node": ">=20 <21"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "sharp": "^0.34.5"
  }
}