# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://invoicekasi:localdev@localhost:5433/invoicekasi

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Used for both access tokens (15m) and refresh token bcrypt signing
JWT_SECRET=change-me-in-production-min-32-chars

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── CORS — must match where the client is served from ───────────────────────
CLIENT_URL=http://localhost:5173

# ─── Client Vite env vars (prefix VITE_ to expose to browser) ────────────────
# Used to construct absolute URLs for uploaded logos in the client
VITE_API_URL=http://localhost:3001

# ─── Yoco payments (optional — only needed for live payment links) ────────────
YOCO_SECRET_KEY=