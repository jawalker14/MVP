# Copy to .env and fill in values. NEVER commit .env.

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://invoicekasi:localdev@localhost:5433/invoicekasi

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-min-32-chars
JWT_REFRESH_SECRET=change-me-in-production-too

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── URLs — must match where client and server are served from ────────────────
CLIENT_URL=http://localhost:5173

# ─── Client Vite env vars (prefix VITE_ to expose to browser) ────────────────
VITE_API_URL=http://localhost:3001

# ─── Yoco payments (optional — only needed for live payment links) ────────────
YOCO_SECRET_KEY=
YOCO_PUBLIC_KEY=

# ─── Yoco webhook signing secret — separate from YOCO_SECRET_KEY ─────────────
# Get from the Yoco dashboard when creating a webhook subscription.
# The value starts with "whsec_"; include the full string as-is.
YOCO_WEBHOOK_SECRET=

# ─── Resend transactional email (optional — falls back to console.log if unset) ─
# Get your API key from https://resend.com (free tier: 100 emails/day)
RESEND_API_KEY=

# ─── Cloudflare R2 (logo storage) ────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=invoicekasi-logos
R2_PUBLIC_BASE_URL=    # e.g. https://logos.invoicekasi.co.za or https://pub-xxx.r2.dev

# ─── Vercel deployment ────────────────────────────────────────────────────────
# Vercel project prefix (the part of the URL before .vercel.app for prod and previews).
# Example: for "mvp-sigma-one.vercel.app" use "mvp-sigma-one".
# Without this set, no .vercel.app origins are allowed.
VERCEL_PROJECT_PREFIX=