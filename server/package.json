{
  "name": "server",
  "version": "0.0.1",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc && cp -r src/db/migrations dist/db/migrations",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "ts-node --transpile-only src/db/migrate.ts",
    "db:migrate:prod": "node dist/db/migrate.js",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@invoicekasi/shared": "*",
    "@aws-sdk/client-s3": "^3.700.0",
    "@types/multer": "^2.1.0",
    "@types/pdfkit": "^0.17.5",
    "bcryptjs": "^3.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.43.1",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "pdfkit": "^0.18.0",
    "postgres": "^3.4.5",
    "resend": "^6.11.0",
    "typescript": "^5.8.3",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.2",
    "drizzle-kit": "^0.31.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0"
  }
}
